# Copy this file to .env and fill in your values
# Google Cloud Vision - set GOOGLE_APPLICATION_CREDENTIALS to your service account JSON path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# LLM API Key (OpenAI)
OPENAI_API_KEY=sk-...

# Two-tier LLM models: cheap primary, stronger escalation on low confidence
LLM_MODEL_PRIMARY=gpt-4.1-nano
LLM_MODEL_ESCALATION=gpt-4.1-mini

# Overall confidence below this triggers escalation to the stronger model
ESCALATION_THRESHOLD=0.6

# Optional: Google OAuth client ID for strict audience validation.
# If set, the backend verifies that incoming ID tokens were issued for this
# specific client. Get it from Google Cloud Console → APIs & Services →
# Credentials → OAuth 2.0 Client IDs → "Web client" (auto created by Google
# Service). If omitted, tokens are still verified for signature + expiry.
GOOGLE_CLIENT_ID=

# Server
HOST=0.0.0.0
PORT=8080

